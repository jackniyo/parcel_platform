    {
      "name": "4. Parcels",
      "item": [

        {
          "name": "Create Parcel",
          "event": [
            {
              "listen": "prerequest",
              "script": { "exec": [
                "// Generate a unique tracking code each run using timestamp",
                "const ts = Date.now().toString().slice(-6);",
                "pm.collectionVariables.set('tracking_code', 'KGL-' + ts);"
              ]}
            },
            {
              "listen": "test",
              "script": { "exec": [
                "pm.test('Status is 201',           () => pm.response.to.have.status(201));",
                "const body = pm.response.json();",
                "pm.test('Status is registered',     () => pm.expect(body.status).to.eql('registered'));",
                "pm.test('tracking_code saved',      () => pm.expect(body.tracking_code).to.eql(pm.collectionVariables.get('tracking_code')));",
                "pm.test('created_at is set',        () => pm.expect(body.created_at).to.not.be.null);",
                "pm.collectionVariables.set('parcel_id', body.id);"
              ]}
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/parcels/", "host": ["{{base_url}}"], "path": ["parcels", ""] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"tracking_code\": \"{{tracking_code}}\",\n  \"sender_phone\": \"0788000001\",\n  \"receiver_phone\": \"0788000002\",\n  \"description\": \"Fragile electronics\",\n  \"weight_kg\": 1.5,\n  \"fee_rwf\": 2000,\n  \"collection_agent_id\": \"{{col_agent_id}}\",\n  \"market_agent_id\": \"{{mkt_agent_id}}\",\n  \"trip_id\": \"{{trip_id}}\"\n}"
