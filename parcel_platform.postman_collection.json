{
  "info": {
    "name": "Parcel Platform API",
    "description": "Full test suite. Run as a Collection (▶ Runner) so variables are shared across requests. Pre-request scripts generate unique phone numbers and tracking codes each run — no duplicate-key errors.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url",      "value": "http://localhost:8000/api/v1" },
    { "key": "agency_id",     "value": "" },
    { "key": "col_agent_id",  "value": "" },
    { "key": "mkt_agent_id",  "value": "" },
    { "key": "trip_id",       "value": "" },
    { "key": "parcel_id",     "value": "" },
    { "key": "col_phone",     "value": "" },
    { "key": "mkt_phone",     "value": "" },
    { "key": "tracking_code", "value": "" }
  ],
  "item": [

    {
      "name": "1. Agencies",
      "item": [

        {
          "name": "Create Agency",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/agencies/", "host": ["{{base_url}}"], "path": ["agencies", ""] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Volcano Express\",\n  \"contact_phone\": \"0781000001\",\n  \"contact_email\": \"info@volcano.rw\"\n}"
            }
          },
          "event": [{
            "listen": "test",
            "script": { "exec": [
              "pm.test('Status is 201',      () => pm.response.to.have.status(201));",
              "const body = pm.response.json();",
              "pm.test('Has id',             () => pm.expect(body.id).to.be.a('string'));",
              "pm.test('active is true',     () => pm.expect(body.active).to.be.true);",
              "pm.test('created_at is set',  () => pm.expect(body.created_at).to.not.be.null);",
              "pm.collectionVariables.set('agency_id', body.id);"
            ]}
          }]
        },

        {
          "name": "List Agencies",
          "request": {
            "method": "GET",
            "url": { "raw": "{{base_url}}/agencies/", "host": ["{{base_url}}"], "path": ["agencies", ""] }
          },
          "event": [{
            "listen": "test",
            "script": { "exec": [
              "pm.test('Status is 200',      () => pm.response.to.have.status(200));",
              "pm.test('Returns an array',   () => pm.expect(pm.response.json()).to.be.an('array'));",
              "pm.test('At least 1 result',  () => pm.expect(pm.response.json().length).to.be.at.least(1));"
            ]}
          }]
        },

        {
          "name": "List Active Agencies Only",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/agencies/?active_only=true",
              "host": ["{{base_url}}"], "path": ["agencies", ""],
              "query": [{ "key": "active_only", "value": "true" }]
            }
          },
          "event": [{
            "listen": "test",
            "script": { "exec": [
              "pm.test('Status is 200',   () => pm.response.to.have.status(200));",
              "const body = pm.response.json();",
              "pm.test('All are active',  () => body.forEach(a => pm.expect(a.active).to.be.true));"
            ]}
          }]
        },

        {
          "name": "Get Agency by ID",
          "request": {
            "method": "GET",
            "url": { "raw": "{{base_url}}/agencies/{{agency_id}}", "host": ["{{base_url}}"], "path": ["agencies", "{{agency_id}}"] }
          },
          "event": [{
            "listen": "test",
            "script": { "exec": [
              "pm.test('Status is 200',           () => pm.response.to.have.status(200));",
              "pm.test('Returns correct agency',   () => pm.expect(pm.response.json().id).to.eql(pm.collectionVariables.get('agency_id')));"
            ]}
          }]
        },

        {
          "name": "Get Agency — 404",
          "request": {
            "method": "GET",
            "url": { "raw": "{{base_url}}/agencies/nonexistent-id", "host": ["{{base_url}}"], "path": ["agencies", "nonexistent-id"] }
          },
          "event": [{
            "listen": "test",
            "script": { "exec": [
              "pm.test('Status is 404', () => pm.response.to.have.status(404));"
            ]}
          }]
        },

        {
          "name": "Deactivate Agency",
          "request": {
            "method": "PATCH",
            "url": { "raw": "{{base_url}}/agencies/{{agency_id}}/deactivate", "host": ["{{base_url}}"], "path": ["agencies", "{{agency_id}}", "deactivate"] }
          },
          "event": [{
            "listen": "test",
            "script": { "exec": [
              "pm.test('Status is 200',    () => pm.response.to.have.status(200));",
              "pm.test('active is false',  () => pm.expect(pm.response.json().active).to.be.false);"
            ]}
          }]
        },

        {
          "name": "Delete Agency",
          "request": {
            "method": "DELETE",
            "url": { "raw": "{{base_url}}/agencies/{{agency_id}}", "host": ["{{base_url}}"], "path": ["agencies", "{{agency_id}}"] }
          },
          "event": [{
            "listen": "test",
            "script": { "exec": [
              "pm.test('Status is 204', () => pm.response.to.have.status(204));"
            ]}
          }]
        },

        {
          "name": "Re-create Agency (for remaining tests)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/agencies/", "host": ["{{base_url}}"], "path": ["agencies", ""] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Volcano Express Active\",\n  \"contact_phone\": \"0781000099\",\n  \"contact_email\": \"ops@volcano.rw\"\n}"
            }
          },
          "event": [{
            "listen": "test",
            "script": { "exec": [
              "pm.test('Status is 201', () => pm.response.to.have.status(201));",
              "pm.collectionVariables.set('agency_id', pm.response.json().id);"
            ]}
          }]
        }

      ]
    },

    {
      "name": "2. Agents",
      "item": [

        {
          "name": "Create Collection Agent",
          "event": [
            {
              "listen": "prerequest",
              "script": { "exec": [
                "// Generate a unique 10-digit phone using timestamp so re-runs never collide",
                "const ts = Date.now().toString().slice(-7);",
                "pm.collectionVariables.set('col_phone', '0782' + ts);"
              ]}
            },
            {
              "listen": "test",
              "script": { "exec": [
                "pm.test('Status is 201',      () => pm.response.to.have.status(201));",
                "const body = pm.response.json();",
                "pm.test('Role is collection', () => pm.expect(body.role).to.eql('collection'));",
                "pm.test('active is true',     () => pm.expect(body.active).to.be.true);",
                "pm.collectionVariables.set('col_agent_id', body.id);"
              ]}
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/agents/", "host": ["{{base_url}}"], "path": ["agents", ""] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"agency_id\": \"{{agency_id}}\",\n  \"name\": \"Jean Collector\",\n  \"phone\": \"{{col_phone}}\",\n  \"role\": \"collection\",\n  \"location_name\": \"Kimironko Market\",\n  \"district\": \"Gasabo\"\n}"
            }
          }
        },

        {
          "name": "Create Market Agent",
          "event": [
            {
              "listen": "prerequest",
              "script": { "exec": [
                "// Add 1 to ensure a different number from the collection agent",
                "const ts = (Date.now() + 1).toString().slice(-7);",
                "pm.collectionVariables.set('mkt_phone', '0783' + ts);"
              ]}
            },
            {
              "listen": "test",
              "script": { "exec": [
                "pm.test('Status is 201',   () => pm.response.to.have.status(201));",
                "const body = pm.response.json();",
                "pm.test('Role is market',  () => pm.expect(body.role).to.eql('market'));",
                "pm.collectionVariables.set('mkt_agent_id', body.id);"
              ]}
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/agents/", "host": ["{{base_url}}"], "path": ["agents", ""] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"agency_id\": \"{{agency_id}}\",\n  \"name\": \"Marie Market\",\n  \"phone\": \"{{mkt_phone}}\",\n  \"role\": \"market\",\n  \"location_name\": \"Nyabugogo\",\n  \"district\": \"Nyarugenge\"\n}"
            }
          }
        },

        {
          "name": "Create Agent — 404 bad agency",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/agents/", "host": ["{{base_url}}"], "path": ["agents", ""] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"agency_id\": \"nonexistent\",\n  \"name\": \"Ghost\",\n  \"phone\": \"0799999999\",\n  \"role\": \"hub\"\n}"
            }
          },
          "event": [{
            "listen": "test",
            "script": { "exec": [
              "pm.test('Status is 404', () => pm.response.to.have.status(404));"
            ]}
          }]
        },

        {
          "name": "Create Agent — 409 duplicate phone",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/agents/", "host": ["{{base_url}}"], "path": ["agents", ""] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"agency_id\": \"{{agency_id}}\",\n  \"name\": \"Duplicate\",\n  \"phone\": \"{{col_phone}}\",\n  \"role\": \"hub\"\n}"
            }
          },
          "event": [{
            "listen": "test",
            "script": { "exec": [
              "pm.test('Status is 409', () => pm.response.to.have.status(409));"
            ]}
          }]
        },

        {
          "name": "List Agents",
          "request": {
            "method": "GET",
            "url": { "raw": "{{base_url}}/agents/", "host": ["{{base_url}}"], "path": ["agents", ""] }
          },
          "event": [{
            "listen": "test",
            "script": { "exec": [
              "pm.test('Status is 200',    () => pm.response.to.have.status(200));",
              "pm.test('Returns an array', () => pm.expect(pm.response.json()).to.be.an('array'));"
            ]}
          }]
        },

        {
          "name": "List Agents — filter by role",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/agents/?role=collection",
              "host": ["{{base_url}}"], "path": ["agents", ""],
              "query": [{ "key": "role", "value": "collection" }]
            }
          },
          "event": [{
            "listen": "test",
            "script": { "exec": [
              "pm.test('Status is 200', () => pm.response.to.have.status(200));",
              "const body = pm.response.json();",
              "pm.test('All collection', () => body.forEach(a => pm.expect(a.role).to.eql('collection')));"
            ]}
          }]
        },

        {
          "name": "Get Agent by ID",
          "request": {
            "method": "GET",
            "url": { "raw": "{{base_url}}/agents/{{col_agent_id}}", "host": ["{{base_url}}"], "path": ["agents", "{{col_agent_id}}"] }
          },
          "event": [{
            "listen": "test",
            "script": { "exec": [
              "pm.test('Status is 200',           () => pm.response.to.have.status(200));",
              "pm.test('Returns correct agent',    () => pm.expect(pm.response.json().id).to.eql(pm.collectionVariables.get('col_agent_id')));"
            ]}
          }]
        },

        {
          "name": "Deactivate Agent",
          "request": {
            "method": "PATCH",
            "url": { "raw": "{{base_url}}/agents/{{col_agent_id}}/deactivate", "host": ["{{base_url}}"], "path": ["agents", "{{col_agent_id}}", "deactivate"] }
          },
          "event": [{
            "listen": "test",
            "script": { "exec": [
              "pm.test('Status is 200',    () => pm.response.to.have.status(200));",
              "pm.test('active is false',  () => pm.expect(pm.response.json().active).to.be.false);"
            ]}
          }]
        }

      ]
    },

    {
