          "event": [{
            "listen": "test",
            "script": { "exec": [
              "pm.test('Status is 200',           () => pm.response.to.have.status(200));",
              "pm.test('Returns correct parcel',   () => pm.expect(pm.response.json().id).to.eql(pm.collectionVariables.get('parcel_id')));"
            ]}
          }]
        },

        {
          "name": "Update Status → in_transit",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/parcels/{{parcel_id}}/status", "host": ["{{base_url}}"], "path": ["parcels", "{{parcel_id}}", "status"] },
            "body": { "mode": "raw", "raw": "{\n  \"status\": \"in_transit\"\n}" }
          },
          "event": [{
            "listen": "test",
            "script": { "exec": [
              "pm.test('Status is 200',       () => pm.response.to.have.status(200));",
              "pm.test('Status in_transit',    () => pm.expect(pm.response.json().status).to.eql('in_transit'));"
            ]}
          }]
        },

        {
          "name": "Update Status → collected",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/parcels/{{parcel_id}}/status", "host": ["{{base_url}}"], "path": ["parcels", "{{parcel_id}}", "status"] },
            "body": { "mode": "raw", "raw": "{\n  \"status\": \"collected\"\n}" }
          },
          "event": [{
            "listen": "test",
            "script": { "exec": [
              "pm.test('Status is 200',     () => pm.response.to.have.status(200));",
              "pm.test('Status collected',   () => pm.expect(pm.response.json().status).to.eql('collected'));"
            ]}
          }]
        },

        {
          "name": "Add Parcel Event (manual note)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/parcels/{{parcel_id}}/events", "host": ["{{base_url}}"], "path": ["parcels", "{{parcel_id}}", "events"] },
            "body": { "mode": "raw", "raw": "{\n  \"event_type\": \"at_hub\",\n  \"actor_id\": \"{{col_agent_id}}\",\n  \"note\": \"Arrived at Kigali hub\"\n}" }
          },
          "event": [{
            "listen": "test",
            "script": { "exec": [
              "pm.test('Status is 201',    () => pm.response.to.have.status(201));",
              "const body = pm.response.json();",
              "pm.test('event_type saved', () => pm.expect(body.event_type).to.eql('at_hub'));",
              "pm.test('note saved',       () => pm.expect(body.note).to.eql('Arrived at Kigali hub'));"
            ]}
          }]
        },

        {
          "name": "Get Parcel Event History",
          "request": {
            "method": "GET",
            "url": { "raw": "{{base_url}}/parcels/{{parcel_id}}/events", "host": ["{{base_url}}"], "path": ["parcels", "{{parcel_id}}", "events"] }
          },
          "event": [{
            "listen": "test",
            "script": { "exec": [
              "pm.test('Status is 200',            () => pm.response.to.have.status(200));",
              "const body = pm.response.json();",
              "pm.test('Returns an array',          () => pm.expect(body).to.be.an('array'));",
              "pm.test('At least 2 events',         () => pm.expect(body.length).to.be.at.least(2));",
              "pm.test('First event is registered', () => pm.expect(body[0].event_type).to.eql('registered'));"
            ]}
          }]
        }

      ]
